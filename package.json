{
  "private": true,
  "name": "@tinijs/monorepo",
  "version": "0.0.0",
  "description": "The TiniJS Framework.",
  "author": "Nhan Lam",
  "homepage": "https://tinijs.dev",
  "license": "MIT",
  "engines": {
    "node": ">=18.15.0",
    "npm": ">=7.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "Javascript",
    "Framework",
    "Web Component",
    "Lit",
    "Angular",
    "Vue",
    "React",
    "Svelte",
    "Vite",
    "Nuxt",
    "Next",
    "SvelteKit"
  ],
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "lerna run build",
    "test": "lerna run test",
    "test:coverage": "npm run test:coverage -w @tinijs/toolbox && npm run test:coverage -w @tinijs/ui",
    "test:e2e": "npm run test:e2e -w demo-command-palette",
    "lint": "lerna run lint",
    "fix": "lerna run fix",
    "typecheck": "lerna run build",
    "format": "prettier --write .",
    "benchmark": "tsx ./scripts/benchmark.mts",
    "release": "lerna publish --no-private --force-publish --conventional-commits && tsx ./scripts/release-ui.mts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinijs/tinijs.git"
  },
  "bugs": {
    "url": "https://github.com/tinijs/tinijs/issues"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^1.6.1",
    "chrome-launcher": "^1.1.2",
    "colorette": "^2.0.20",
    "consola": "^3.2.3",
    "cross-os": "^1.5.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "gts": "^5.3.0",
    "lerna": "^8.1.2",
    "lighthouse": "^12.0.0",
    "mri": "^1.2.0",
    "pathe": "^1.1.2",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.2",
    "tty-table": "^4.2.3",
    "type-fest": "^4.14.0",
    "typedoc": "^0.25.12",
    "typescript": "^5.4.3",
    "vitest": "^1.4.0"
  }
}
